{
  "project": {
    "name": "PagePay",
    "tagline": "Read Stories & AI Exam Prep",
    "brand": {
      "primaryColor": "#6C5CE7",
      "secondaryColor": "#00B894",
      "font": "Inter",
      "logoText": "PagePay",
      "tone": "professional yet rewarding"
    }
  },
  "techStack": {
    "frontend": {
      "framework": "Expo SDK 55+",
      "reactNative": "0.83",
      "react": "19.2",
      "navigation": "expo-router",
      "stateManagement": {
        "server": "TanStack Query v5",
        "client": "Zustand",
        "persistent": "MMKV"
      },
      "architecture": "New Architecture (mandatory)",
      "build": "expo-dev-client (EAS Build)"
    },
    "backend": {
      "framework": "FastAPI (Python 3.11+)",
      "database": "MySQL 8.0",
      "orm": "SQLAlchemy 2.0 (async)",
      "driver": "asyncmy",
      "deployment": "Docker container"
    },
    "ads": {
      "primary": "Google AdMob (mediation layer)",
      "secondary": "AppLovin MAX (rewarded video)",
      "plugin": "@fumitakayamada/expo-applovin-max"
    },
    "ai": {
      "router": "Custom Python failover system",
      "primary": "Google AI Studio (Gemini 2.5 Flash)",
      "secondary": "Groq (Llama 3.3 70B)",
      "tertiary": "OpenRouter (free models)",
      "optional": "Cerebras (volatile)"
    },
    "payments": {
      "primary": "Flutterwave v4 (OAuth 2.0)",
      "fallback": "Paystack"
    }
  },
