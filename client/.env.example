# client/.env.example
# Copy to .env (or .env.local) and fill in real values. Never commit
# real keys — `.env*` should be added to `.gitignore` so real secrets
# stay out of git history.

# Backend API base URL. The Expo client uses this for every fetch.
# For an Android emulator on the same machine as the dev backend,
# `http://10.0.2.2:8000` is the right value. For a real device on the
# LAN, use the dev machine's LAN IP (e.g. http://192.168.1.10:8000).
EXPO_PUBLIC_API_URL=http://localhost:8000

# Ad environment. `dev` returns Google's documented test unit IDs from
# /api/v1/config/ads (so dev builds never burn real impressions against
# the production account). `prod` returns the PagePay IDs the ops team
# seeded in `app_config`. CI sets this to `prod` before the staging build.
EXPO_PUBLIC_ADS_ENV=dev

# Paystack (Phase 4 — Payments).
#
# `PAYSTACK_PUBLIC_KEY` is read by the Expo client (Paystack inline
# / popup flows — Phase 4 frontend inline checkout, future premium
# upgrade). Safe to expose in the bundle.
#
# `PAYSTACK_SECRET_KEY` and `PAYSTACK_WEBHOOK_SECRET` are SERVER-ONLY.
# The backend (`backend/.env`) is the correct place for them; we keep
# these names here so the dev workflow doesn't get surprising
# "where does this var live?" questions. Do NOT fill in real values
# in this client file — paste them into `backend/.env` instead.
#
# Get keys from https://dashboard.paystack.com/#/settings/developers.
PAYSTACK_PUBLIC_KEY=
# PAYSTACK_SECRET_KEY=    # SERVER-ONLY — set in backend/.env
# PAYSTACK_WEBHOOK_SECRET= # SERVER-ONLY — set in backend/.env
