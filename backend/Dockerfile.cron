FROM python:3.11-slim
RUN useradd --create-home appuser
WORKDIR /app
COPY requirements.txt ./
RUN pip install --retries 10 -r requirements.txt
COPY app ./app
USER appuser
# Default entrypoint runs the cron module. docker-compose overrides the
# command with a sleep loop for scheduled runs.
CMD ["python", "-m", "app.services.cron"]
